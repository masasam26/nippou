generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  sales
  manager
}

enum ReportStatus {
  draft
  submitted
}

model User {
  userId     Int      @id @default(autoincrement()) @map("user_id")
  name       String   @db.VarChar(50)
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255)
  role       Role
  department String?  @db.VarChar(100)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  dailyReports DailyReport[]
  comments     Comment[]

  @@map("users")
}

model Customer {
  customerId   Int      @id @default(autoincrement()) @map("customer_id")
  companyName  String   @db.VarChar(100) @map("company_name")
  contactName  String?  @db.VarChar(50) @map("contact_name")
  address      String?  @db.VarChar(200)
  phone        String?  @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")

  visitRecords VisitRecord[]

  @@map("customers")
}

model DailyReport {
  reportId   Int          @id @default(autoincrement()) @map("report_id")
  userId     Int          @map("user_id")
  reportDate DateTime     @map("report_date") @db.Date
  problem    String?      @db.Text
  plan       String?      @db.Text
  status     ReportStatus @default(draft)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [userId])
  visitRecords VisitRecord[]
  comments     Comment[]

  @@unique([userId, reportDate])
  @@map("daily_reports")
}

model VisitRecord {
  visitId      Int      @id @default(autoincrement()) @map("visit_id")
  reportId     Int      @map("report_id")
  customerId   Int      @map("customer_id")
  visitContent String   @db.Text @map("visit_content")
  visitOrder   Int      @map("visit_order")
  createdAt    DateTime @default(now()) @map("created_at")

  dailyReport DailyReport @relation(fields: [reportId], references: [reportId])
  customer    Customer    @relation(fields: [customerId], references: [customerId])

  @@map("visit_records")
}

model Comment {
  commentId Int      @id @default(autoincrement()) @map("comment_id")
  reportId  Int      @map("report_id")
  userId    Int      @map("user_id")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  dailyReport DailyReport @relation(fields: [reportId], references: [reportId])
  user        User        @relation(fields: [userId], references: [userId])

  @@map("comments")
}
